% patches.sty -- enhancements for the JFM LaTeX template, re-derived for the
% 2025 official template (JFM-FLM_Au.cls).  Load it in the preamble with
%
%     \usepackage{patches}
%
% and select the enhanced bibliography style with
%
%     \bibliographystyle{jfm_jabbrv}
%
% Marie-Jean Thoraval (mjthoraval@gmail.com).  Builds on jabbrv (Erich Hoover),
% hyperref, and a natbib (P.W. Daly) \NAT@citex patch for year-only citation links;
% the sources for each technique are cited in the in-file comments below.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{patches}[2025/06/18 JFM template enhancements: jabbrv + DOI/year hyperlinks]

% ---------------------------------------------------------------------------
% Journal-title abbreviation
% ---------------------------------------------------------------------------
% jfm_jabbrv.bst wraps every journal name in \JournalTitle{...}; the jabbrv
% package turns that into the ISO-4 abbreviation (e.g. "Journal of Fluid
% Mechanics" -> "J. Fluid Mech.").  Remove [warnundef] to silence the
% "abbreviation not found" warnings for words jabbrv does not know.
\usepackage[warnundef]{jabbrv}
% Project-specific / custom abbreviations live in jabbrv-jfm.ldf, kept separate
% so that jabbrv.sty itself can be updated from
% https://github.com/compholio/jabbrv without losing them.
\makeatletter
\InputIfFileExists{jabbrv-jfm.ldf}{}{%
  \@latex@error{Abbreviation file `jabbrv-jfm.ldf' not found}%
               {Put jabbrv-jfm.ldf next to your .tex file and recompile.}%
}
\makeatother

% ---------------------------------------------------------------------------
% Reference and citation hyperlinks
% ---------------------------------------------------------------------------
% JFM-FLM_Au.cls already loads hyperref (and breakurl, and natbib), so we must
% NOT load hyperref again with options (that would raise an option clash) --
% we only adjust its settings here.
\hypersetup{breaklinks=true,colorlinks=true,%
            linkcolor=blue,citecolor=blue,urlcolor=blue,%
            hypertexnames=false}
\usepackage[all]{hypcap} % make links jump to the figure, not its caption

% Show the citation hyperlink on the YEAR only (as in the published articles),
% instead of the whole "Author (year)".  Patches natbib's \NAT@citex.
% https://tex.stackexchange.com/questions/23227
% natbib is already loaded by the class; the bundled natbib.sty (v8.31b) is the
% version these patches were written against.
\usepackage{etoolbox}
\makeatletter
\patchcmd{\NAT@citex}
  {\@citea\NAT@hyper@{%
     \NAT@nmfmt{\NAT@nm}%
     \hyper@natlinkbreak{\NAT@aysep\NAT@spacechar}{\@citeb\@extra@b@citeb}%
     \NAT@date}}
  {\@citea\NAT@nmfmt{\NAT@nm}%
   \NAT@aysep\NAT@spacechar\NAT@hyper@{\NAT@date}}
  {}
  {\PackageWarning{patches}{NAT@citex year-link patch 1 did not apply (natbib changed?)}}
\patchcmd{\NAT@citex}
  {\@citea\NAT@hyper@{%
     \NAT@nmfmt{\NAT@nm}%
     \hyper@natlinkbreak{\NAT@spacechar\NAT@@open\if*#1*\else#1\NAT@spacechar\fi}%
       {\@citeb\@extra@b@citeb}%
     \NAT@date}}
  {\@citea\NAT@nmfmt{\NAT@nm}%
   \NAT@spacechar\NAT@@open\if*#1*\else#1\NAT@spacechar\fi\NAT@hyper@{\NAT@date}}
  {}
  {\PackageWarning{patches}{NAT@citex year-link patch 2 did not apply (natbib changed?)}}
\makeatother

